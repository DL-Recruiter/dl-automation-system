                      "inputs": "<p class=\"editor-paragraph\">This is a final reminder regarding the background check for @{if(empty(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_CandidateFullName']))),if(empty(trim(string(items('Apply_to_each')?['CandidateItemID_x003a__x0020_Ful/Value']))),items('Apply_to_each')?['CandidateID'],items('Apply_to_each')?['CandidateItemID_x003a__x0020_Ful/Value']),first(body('Get_items_(BGV_FormData)')?['value'])?['F1_CandidateFullName'])}.</p><br><p class=\"editor-paragraph\">@{if(empty(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_CandidateFullName']))),if(empty(trim(string(items('Apply_to_each')?['CandidateItemID_x003a__x0020_Ful/Value']))),items('Apply_to_each')?['CandidateID'],items('Apply_to_each')?['CandidateItemID_x003a__x0020_Ful/Value']),first(body('Get_items_(BGV_FormData)')?['value'])?['F1_CandidateFullName'])} has authorized D L Resources to conduct this background check and provided your contact details for employment verification.</p><br><p class=\"editor-paragraph\">Please complete the form using the link below:<br>@{outputs('FinalVerificationLink')}</p><br><p class=\"editor-paragraph\">Company stamp document for Request ID @{items('Apply_to_each')?['RequestID']}:<br><a href=\"@{outputs('Create_sharing_link_for_company_stamp_document')?['body/link/webUrl']}\">Open Company Stamp - @{items('Apply_to_each')?['RequestID']}.docx</a></p><br><p class=\"editor-paragraph\">Thanks &amp; Regards,<br>D L Resources Pte Ltd<br><br>Phil Wong | HR Officer<br>Co. Reg. No. 199600101K<br>EA License No: 24C2333<br>Tel: +65 8205 9002<br>Email: <a href=\"mailto:recruitment@dlresources.com.sg\">recruitment@dlresources.com.sg</a></p>",
                      "runAfter": {}
                    },
                    "Send_an_email_from_a_shared_mailbox_(V2)_2": {
                      "type": "OpenApiConnection",
                      "inputs": {
                        "parameters": {
                          "emailMessage/MailboxAddress": "recruitment@dlresources.com.sg",
                          "emailMessage/To": "@items('Apply_to_each')?['EmployerHR_Email']",
                          "emailMessage/Subject": "Final Reminder: Employment Verification Request",
