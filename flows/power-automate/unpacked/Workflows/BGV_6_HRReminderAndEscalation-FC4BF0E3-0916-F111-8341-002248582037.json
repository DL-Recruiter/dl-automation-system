                "Condition_-_Close_No_Response_After_Reminder3_5Days": {
                  "type": "If",
                  "runAfter": {
                    "Condition_-_Final_Reminder": [
                      "Succeeded"
                    ]
                  },
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@empty(items('Apply_to_each')?['ResponseReceivedAt'])",
                          true
                        ]
                      },
                      {
                        "equals": [
                          "@empty(items('Apply_to_each')?['Reminder3At'])",
                          false
                        ]
                      },
                      {
