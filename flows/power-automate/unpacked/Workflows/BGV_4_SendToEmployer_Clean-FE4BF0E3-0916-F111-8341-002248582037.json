                  "type": "Compose",
                  "inputs": "@concat('Skipped share link creation. Using direct request folder URL instead: ',concat('https://dlresourcespl88.sharepoint.com/sites/DLRRecruitmentOps570/BGV%20Records/Candidate%20Files/',encodeUriComponent(coalesce(first(body('Get_item')?['value'])?['CandidateID'],items('Apply_to_each_(Requests_Loop)')?['CandidateID'])),'/',encodeUriComponent(items('Apply_to_each_(Requests_Loop)')?['RequestID'])))",
                  "runAfter": {
