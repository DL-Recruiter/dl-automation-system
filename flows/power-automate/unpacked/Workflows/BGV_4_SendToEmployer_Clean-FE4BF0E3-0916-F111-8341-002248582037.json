2449439096683ca0e39241b0=',encodeUriComponent('Yes'),'&r0bef44c0d22d493f95a33484875b951e=',encodeUriComponent(if(and(empty(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentStartDate']),empty(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentEndDate'])),'',if(or(empty(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentStartDate']),empty(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentEndDate'])),formatDateTime(coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentStartDate'],first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentEndDate']),'yyyy-MM-dd'),concat(formatDateTime(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentStartDate'],'yyyy-MM-dd'),' to ',formatDateTime(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmploymentEndDate'],'yyyy-MM-dd'))))),'&r513ad5ab3a14453286bdb910820985ec=',encodeUriComponent(coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F2_ReasonForLeaving'],'')),'&ra6ab2e26d2d84a92b33148fc4694773a=',encodeUriComponent(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_LastDrawnSalary']))),'&r49ca8a655f5e4bcba0e8f75d4475ad77=',encodeUriComponent(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_JobTitle']))),'&rd5d9cb98b1aa47dd8bcd7914cd4bdc87=',encodeUriComponent(concat('https://dlresourcespl88.sharepoint.com/sites/DLRRecruitmentOps570/BGV%20Records/Candidate%20Files/',encodeUriComponent(coalesce(first(body('Get_item')?['value'])?['CandidateID'],items('Apply_to_each_(Requests_Loop)')?['CandidateID'])),'/',encodeUriComponent(items('Apply_to_each_(Requests_Loop)')?['RequestID']))))",
                  "runAfter": {}
                },
                "AuthFolderPath": {
                  "type": "Compose",
                  "inputs": "@concat('/BGV Records/Candidate Files/',coalesce(first(body('Get_item')?['value'])?['CandidateID'], items('Apply_to_each_(Requests_Loop)')?['CandidateID']),'/Authorization/')",
                  "runAfter": {
                    "FinalVerificationLink": [
                      "Succeeded"
                    ]
                  }
                },
                "Create_Request_Stamp_Folder": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "dataset": "https://dlresourcespl88.sharepoint.com/sites/DLRRecruitmentOps570",
                      "table": "8bab5b4d-b441-4f3f-99d4-5bf49557a8e9",
                      "parameters/path": "Candidate Files/@{coalesce(first(body('Get_item')?['value'])?['CandidateID'], items('Apply_to_each_(Requests_Loop)')?['CandidateID'])}/@{items('Apply_to_each_(Requests_Loop)')?['RequestID']}"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline",
                      "operationId": "CreateNewFolder",
                      "connectionName": "shared_sharepointonline"
                    },
                    "authentication": "@parameters('$authentication')"
                  },
                  "runAfter": {}
