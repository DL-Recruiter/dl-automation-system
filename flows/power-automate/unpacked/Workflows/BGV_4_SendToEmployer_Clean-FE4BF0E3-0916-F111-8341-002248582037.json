                "FirstAuthFileIdentifier": {
                  "type": "Compose",
                  "inputs": "@coalesce(first(outputs('Get_files_(properties_only)')?['body/value'])?['{Identifier}'],'')",
                  "runAfter": {
                    "Get_files_(properties_only)": [
                      "Succeeded"
                    ]
                  }
                },
                "FirstAuthFileName": {
                  "type": "Compose",
                  "inputs": "@coalesce(first(outputs('Get_files_(properties_only)')?['body/value'])?['{Name}'],'Authorisation.docx')",
                  "runAfter": {
                    "FirstAuthFileIdentifier": [
                      "Succeeded"
                    ]
                  }
                },
                "Get_file_content": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "dataset": "https://dlresourcespl88.sharepoint.com/sites/DLRRecruitmentOps570",
                      "id": "@outputs('FirstAuthFileIdentifier')",
                      "inferContentType": true
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline",
                      "operationId": "GetFileContent",
                      "connectionName": "shared_sharepointonline"
                    },
                    "authentication": "@parameters('$authentication')"
                  },
                  "runAfter": {
                    "FirstAuthFileName": [
                      "Succeeded"
                    ]
                  }
                },
                "Set_variable": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "AuthFileName",
                    "value": "@outputs('FirstAuthFileName')"
                  },
                  "runAfter": {
                    "Get_file_content": [
                      "Succeeded"
                    ]
                  }
                },
                "EmployerRecipientEmail": {
                  "type": "Compose",
                  "inputs": "@if(and(contains(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_HREmail'])),'@'),not(contains(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_HREmail'])),' ')),contains(last(split(trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_HREmail'])),'@')),'.')),trim(string(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_HREmail'])),if(and(contains(trim(string(items('Apply_to_each_(Requests_Loop)')?['EmployerHR_Email'])),'@'),not(contains(trim(string(items('Apply_to_each_(Requests_Loop)')?['EmployerHR_Email'])),' ')),contains(last(split(trim(string(items('Apply_to_each_(Requests_Loop)')?['EmployerHR_Email'])),'@')),'.')),trim(string(items('Apply_to_each_(Requests_Loop)')?['EmployerHR_Email'])),'dlresplmain@dlresources.com.sg'))",
                  "runAfter": {
                    "Set_variable": [
                      "Succeeded"
                    ]
                  }
                },
                "Send_an_email_(V2)": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "emailMessage/MailboxAddress": "recruitment@dlresources.com.sg",
                      "emailMessage/To": "@outputs('EmployerRecipientEmail')",
                      "emailMessage/Subject": "Request for Employment Verification - @{coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmployerName'],items('Apply_to_each_(Requests_Loop)')?['EmployerName'],'(Not captured)')}",
                      "emailMessage/Body": "<p class=\"editor-paragraph\">Dear HR Department,<br><br>We are reaching out to the Human Resource Department of your company to conduct a Previous Employment Verification Check for</p><p class=\"editor-paragraph\">@{first(body('Get_item')?['value'])?['FullName']}, who has listed your organisation (@{coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmployerName'],items('Apply_to_each_(Requests_Loop)')?['EmployerName'],'(Not captured)')}) as the relevant previous employer.</p><br><p class=\"editor-paragraph\">Declared company details from candidate:</p><p class=\"editor-paragraph\">- Company Name: @{coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmployerName'],items('Apply_to_each_(Requests_Loop)')?['EmployerName'],'(Not captured)')}<br>- Company Address: @{coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmployerAddress'],items('Apply_to_each_(Requests_Loop)')?['EmployerAddress'],items('Apply_to_each_(Requests_Loop)')?['Employer_Address'],'(Not captured)')}<br>- Company UEN: @{coalesce(first(body('Get_items_(BGV_FormData)')?['value'])?['F1_EmployerUEN'],items('Apply_to_each_(Requests_Loop)')?['EmployerUEN'],items('Apply_to_each_(Requests_Loop)')?['Employer_UEN'],'(Not captured)')}</p><br><p class=\"editor-paragraph\"><br>We would greatly appreciate your assistance in completing the \"Previous Employment Verfication Form\" via the link provided below as soon as possible to support a smooth and timely onboarding process. Kindly also prepare your company stamp to be uploaded as a file for the form. (If you do not have a company stamp, you may upload a blank image.)</p><br><p class=\"editor-paragraph\">The following is the link to the form:<br><a href=\"@{outputs('FinalVerificationLink')}\" class=\"editor-link\"><br><br>Click here to complete verification</a><br><br>For your reference, the candidate's signed authorisation has been recorded for this request.</p><br><p class=\"editor-paragraph\">Please be assured that all information provided will be treated with the strictest confidence and used solely for internal HR and employment verification purposes. Please note: if you have any questions or require further information, please reply to this email or include this Request ID in the subject line: @{items('Apply_to_each_(Requests_Loop)')?['RequestID']}.</p><br><p class=\"editor-paragraph\">Thank you for your time and we appreciate your verification.</p><br><p class=\"editor-paragraph\">Thanks &amp; Regards,<br>D L Resources Pte Ltd</p><br>",
                      "emailMessage/Attachments": [
                        {
                          "Name": "@variables('AuthFileName')",
                          "ContentBytes": "@outputs('Get_file_content')?['body/$content']"
                        }
                      ],
                      "emailMessage/Importance": "Normal"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
                      "operationId": "SharedMailboxSendEmailV2",
                      "connectionName": "shared_office365"
                    }
                  },
                  "runAfter": {
                    "EmployerRecipientEmail": [
                      "Succeeded"
                    ]
                  }
                },
                "Send_signed_form_copy_to_candidate_(V2)": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "emailMessage/MailboxAddress": "recruitment@dlresources.com.sg",
                      "emailMessage/To": "@if(contains(trim(string(first(body('Get_item')?['value'])?['CandidateEmail'])),'@'),trim(string(first(body('Get_item')?['value'])?['CandidateEmail'])),'recruitment@dlresources.com.sg')",
                      "emailMessage/Subject": "Employment Verification Sent - @{first(body('Get_item')?['value'])?['FullName']}",
                      "emailMessage/Body": "<p class=\"editor-paragraph\">Dear @{first(body('Get_item')?['value'])?['FullName']},</p><br><p class=\"editor-paragraph\">Your previous employer verification request has been sent for Request ID @{items('Apply_to_each_(Requests_Loop)')?['RequestID']}.</p><br><p class=\"editor-paragraph\">Please keep this email for your reference while we wait for the employer's response.</p><br><p class=\"editor-paragraph\">Thank you.<br>DL Resources Recruitment Team</p>",
                      "emailMessage/Importance": "Normal"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
                      "operationId": "SharedMailboxSendEmailV2",
                      "connectionName": "shared_office365"
                    }
                  },
                  "runAfter": {
                    "Send_an_email_(V2)": [
                      "Succeeded"
                    ]
                  }
                },
                "Update_item_-_BGV_Requests": {
                  "type": "OpenApiConnection",
                  "inputs": {
                    "parameters": {
                      "dataset": "https://dlresourcespl88.sharepoint.com/sites/DLRRecruitmentOps570",
                      "table": "a27f05fc-84e5-4784-b7ee-ef6e1d145284",
                      "id": "@items('Apply_to_each_(Requests_Loop)')?['ID']",
                      "item/Title": "@items('Apply_to_each_(Requests_Loop)')?['Title']",
                      "item/HRRequestSentAt": "@utcNow()",
                      "item/VerificationStatus/Value": "Email Sent",
                      "item/uniquelinktoemployers": "@outputs('FinalVerificationLink')"
                    },
                    "host": {
                      "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline",
                      "operationId": "PatchItem",
                      "connectionName": "shared_sharepointonline"
                    }
                  },
                  "runAfter": {
                    "Send_signed_form_copy_to_candidate_(V2)": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Should_Send_Request_Now": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
            "Get_items_(BGV_Requests)": [
              "Succeeded"
            ]
          }
        }
      },
      "outputs": {}
    },
    "templateName": null
