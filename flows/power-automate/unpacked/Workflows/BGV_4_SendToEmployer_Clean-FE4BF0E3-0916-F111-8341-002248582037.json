                ]
              }
            },
            "Should_Send_Request_Now": {
              "type": "Compose",
              "inputs": "@or(not(endsWith(string(items('Apply_to_each_(Requests_Loop)')?['RequestID']), '-EMP1')),empty(items('Apply_to_each_(Requests_Loop)')?['SendAfterDate']),lessOrEquals(formatDateTime(items('Apply_to_each_(Requests_Loop)')?['SendAfterDate'], 'yyyy-MM-dd'),formatDateTime(utcNow(), 'yyyy-MM-dd')))",
              "runAfter": {
